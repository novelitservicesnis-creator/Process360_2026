@Process360.API_HostAddress = https://localhost:7001
@ContentType = application/json

###
### ============================================================
### CUSTOMERS ENDPOINTS
### ============================================================

### Get all customers
GET {{Process360.API_HostAddress}}/api/v1/customers
Accept: {{ContentType}}

###

### Get customer by ID
GET {{Process360.API_HostAddress}}/api/v1/customers/1
Accept: {{ContentType}}

###

### Create customer
POST {{Process360.API_HostAddress}}/api/v1/customers
Content-Type: {{ContentType}}

{
  "login": "john.doe",
  "name": "John Doe"
}

###

### Update customer
PUT {{Process360.API_HostAddress}}/api/v1/customers/1
Content-Type: {{ContentType}}

{
  "login": "jane.doe",
  "name": "Jane Doe"
}

###

### Delete customer
DELETE {{Process360.API_HostAddress}}/api/v1/customers/1

###
### ============================================================
### PROJECTS ENDPOINTS
### ============================================================

### Get all projects
GET {{Process360.API_HostAddress}}/api/v1/projects
Accept: {{ContentType}}

###

### Get project by ID
GET {{Process360.API_HostAddress}}/api/v1/projects/1
Accept: {{ContentType}}

###

### Create project
POST {{Process360.API_HostAddress}}/api/v1/projects
Content-Type: {{ContentType}}

{
  "code": "PRJ001",
  "name": "Project Management System",
  "description": "A comprehensive project management solution"
}

###

### Update project
PUT {{Process360.API_HostAddress}}/api/v1/projects/1
Content-Type: {{ContentType}}

{
  "code": "PRJ001",
  "name": "Updated Project Name",
  "description": "Updated description"
}

###

### Delete project
DELETE {{Process360.API_HostAddress}}/api/v1/projects/1

###
### ============================================================
### PROJECT TASKS ENDPOINTS
### ============================================================

### Get all project tasks
GET {{Process360.API_HostAddress}}/api/v1/projecttasks
Accept: {{ContentType}}

###

### Get project task by ID
GET {{Process360.API_HostAddress}}/api/v1/projecttasks/1
Accept: {{ContentType}}

###

### Create project task
POST {{Process360.API_HostAddress}}/api/v1/projecttasks
Content-Type: {{ContentType}}

{
  "title": "Design Database Schema",
  "description": "Create and design the database schema for the application",
  "projectId": 1,
  "projectTaskTypeId": 1,
  "assignedResourceId": 1
}

###

### Update project task
PUT {{Process360.API_HostAddress}}/api/v1/projecttasks/1
Content-Type: {{ContentType}}

{
  "title": "Updated Task Title",
  "description": "Updated description",
  "status": "In Progress"
}

###

### Delete project task
DELETE {{Process360.API_HostAddress}}/api/v1/projecttasks/1

